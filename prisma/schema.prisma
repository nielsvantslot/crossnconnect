// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id              String    @id @default(cuid())
  email           String    @unique @db.VarChar(255)
  password        String    @db.VarChar(255)
  name            String    @db.VarChar(100)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  sessions        Session[]
  accounts        Account[]
  acceptedMembers Member[]  @relation("MemberAcceptedBy")
}

model Account {
  id                String  @id @default(cuid())
  adminId           String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  adminId      String
  expires      DateTime
  admin        Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Member {
  id         String        @id @default(cuid())
  
  // Personal Information
  firstName      String        @db.VarChar(100)
  lastName       String        @db.VarChar(100)
  dateOfBirth    DateTime
  city           String        @db.VarChar(100)
  phone          String        @db.VarChar(20)
  email          String        @unique @db.VarChar(255)
  
  // Payment Information (ENCRYPTED in application layer)
  // WARNING: iban field contains AES-256-GCM encrypted data
  // Use encryptIBAN/decryptIBAN from lib/encryption.ts
  accountHolderName String      @db.VarChar(200)
  iban              String      @db.VarChar(500) // Encrypted IBAN (format: iv:authTag:encryptedData)
  
  // Profile & Work (NORMALIZED)
  occupationId      String?
  occupation        Occupation? @relation(fields: [occupationId], references: [id])
  industryId        String?
  industry          Industry?   @relation(fields: [industryId], references: [id])
  companyName       String?     @db.VarChar(200)
  companyRole       String?     @db.VarChar(100)
  
  // Horse Sport Experience (NORMALIZED with ENUMS)
  hasHorseExperience   Boolean
  horseExperienceLevel HorseExperienceLevel?
  wantsToDiscover      Boolean?
  
  // Relationships for normalized data
  disciplines       MemberDiscipline[]     // Many-to-many with Discipline
  communityGoals    MemberCommunityGoal[]  // Many-to-many with CommunityGoal
  
  // Fun Question
  funAnswer         String        @db.Text
  
  // Privacy & Consent
  consentGiven      Boolean       @default(true)
  
  // Status & Timestamps
  status            MemberStatus  @default(PENDING)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  acceptedAt        DateTime?
  
  // Audit Trail
  acceptedById      String?
  acceptedBy        Admin?        @relation("MemberAcceptedBy", fields: [acceptedById], references: [id])
  
  // GDPR: Soft Delete & Data Retention
  deletedAt         DateTime?
  dataRetentionUntil DateTime?    // Auto-delete after X years if not accepted
  
  @@index([email])
  @@index([status])
  @@index([lastName])
  @@index([createdAt])
  @@index([status, createdAt])  // Composite for "recent pending members"
  @@index([hasHorseExperience, status])  // Composite for filtering
  @@index([deletedAt])  // For soft delete queries
  @@index([occupationId])
  @@index([industryId])
}

// NEW: Normalized Occupation
model Occupation {
  id                   String    @id @default(cuid())
  name                 String    @unique @db.VarChar(100)
  nameEn               String?   @db.VarChar(100)
  requiresWorkDetails  Boolean   @default(false)
  order                Int       @default(0)
  members              Member[]
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  
  @@index([order])
}

// NEW: Normalized Industry
model Industry {
  id        String    @id @default(cuid())
  name      String    @unique @db.VarChar(100)
  nameEn    String?   @db.VarChar(100)
  order     Int       @default(0)
  members   Member[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  @@index([order])
}

// NEW: ENUM for Horse Experience Level
enum HorseExperienceLevel {
  ACTIVE  // Actief ruiter / eigenaar / werkzaam in sector
  FAN     // Liefhebber / fan
}

enum MemberStatus {
  PENDING
  ACCEPTED
  DENIED
}

// Normalized Discipline options (now allows dynamic creation)
model Discipline {
  id         String              @id @default(cuid())
  name       String              @unique @db.VarChar(100)
  nameEn     String?             @db.VarChar(100)
  order      Int                 @default(0)
  isPredefined Boolean           @default(true)  // False for user-created disciplines
  members    MemberDiscipline[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  
  @@index([order])
  @@index([isPredefined])
}

// Junction table for Member <-> Discipline (many-to-many)
model MemberDiscipline {
  memberId     String
  disciplineId String
  member       Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  discipline   Discipline @relation(fields: [disciplineId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  
  @@id([memberId, disciplineId])
  @@index([memberId])
  @@index([disciplineId])
}

// Normalized Community Goal options
model CommunityGoal {
  id        String                 @id @default(cuid())
  name      String                 @unique @db.VarChar(100)
  nameEn    String?                @db.VarChar(100)
  order     Int                    @default(0)
  members   MemberCommunityGoal[]
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  
  @@index([order])
}

// Junction table for Member <-> CommunityGoal (many-to-many)
model MemberCommunityGoal {
  memberId        String
  communityGoalId String
  member          Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  communityGoal   CommunityGoal @relation(fields: [communityGoalId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())
  
  @@id([memberId, communityGoalId])
  @@index([memberId])
  @@index([communityGoalId])
}

model TrackableUrl {
  id          String   @id @default(cuid())
  slug        String   @unique @db.VarChar(100)
  name        String   @db.VarChar(200)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  clicks      Click[]
  
  @@index([slug])
}

model Click {
  id             String       @id @default(cuid())
  trackableUrl   TrackableUrl @relation(fields: [trackableUrlId], references: [id], onDelete: Cascade)
  trackableUrlId String
  ipAddressHash  String?      @db.VarChar(64)  // SHA-256 hash for privacy (GDPR compliant)
  userAgent      String?      @db.Text
  clickedAt      DateTime     @default(now())
  
  @@index([trackableUrlId])
  @@index([ipAddressHash])
}
