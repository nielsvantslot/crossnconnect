# Database - Local Development
DATABASE_URL="postgresql://username:password@localhost:5432/crossnconnect_waitlist?schema=public"

# Database - Docker (use this when running with docker-compose)
# DATABASE_URL="postgresql://postgres:postgres@postgres:5432/crossnconnect_waitlist?schema=public"

# NextAuth
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# IBAN Encryption
# Generate with: node scripts/generate-encryption-key.js
# CRITICAL: Keep this secret and never commit to Git
# If lost, encrypted IBANs cannot be recovered
ENCRYPTION_KEY="your-encryption-key-here"
